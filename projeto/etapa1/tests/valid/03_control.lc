/* 03_control.lc — Controle de fluxo
 * Testa: if/else, while...do, for, operadores relacionais e lógicos.
 */

fun int fatorial(int n) {
    if (n <= 1) {
        return 1 ;
    } else {
        return n * fatorial(n - 1) ;
    }
}

fun void main() {
    let x := 5 ;

    /* if simples */
    if (x > 0) {
        print x ;
    }

    /* if-else */
    if (x == 0) {
        print 0 ;
    } else {
        print x ;
    }

    /* while ... do */
    let i := 0 ;
    while (i < 10) do {
        i := i + 1 ;
    }

    /* for */
    let j := 0 ;
    for (j := 0 ; j < 5 ; j := j + 1) {
        print j ;
    }

    /* operadores lógicos && e || */
    if (x > 0 && x < 100) {
        print x ;
    }

    if (x == 0 || x > 3) {
        print x ;
    }
}
